<h1>List of games</h1>

<ul id="game-list">
    {{#each games}}
        <li id="game-{{id}}">
            <a href="/games/{{id}}">{{name}}</a>
            <form action="/games/{{id}}/delete" method="POST" style="display:inline;">
                <button type="submit">Delete</button>
            </form>
            <form>
                <input type="checkbox" class="checkboxFav" data-game-id="{{id}}">
                <label for="checkboxFav">Put in favourite</label>
            </form>
        </li>
    {{/each}}
</ul>

<a href="/games/new">
    <button>Add game</button>
</a>



